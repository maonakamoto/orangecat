#!/usr/bin/env sh

# Skip tests for branch deletions (no code is being pushed)
if read local_ref local_oid remote_ref remote_oid; then
  if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
    exit 0
  fi
fi

echo "🚀 Running pre-push checks..."

# Type-check FIRST — pre-commit's incremental check can miss errors under
# concurrent builds (stale .tsbuildinfo); this non-incremental run is the
# reliable gate, so type errors are caught before push, not at deploy/build.
echo "🔎 Type-checking..."
npm run type-check || { echo "❌ Type check failed"; exit 1; }
echo "✅ Type check passed"

# Run tests before pushing (target: ≤30s)

echo "🧭 Checking route integrity..."
npm run audit:routes || { echo "❌ Route audit failed — a declared or emitted link resolves to no route"; exit 1; }
echo "✅ Route audit passed"

echo "🧪 Running unit tests..."
npm run test:unit || { echo "❌ Unit tests failed"; exit 1; }
echo "✅ Unit tests passed"

echo "🎭 Running fast E2E tests..."
if curl -sf "${BASE_URL:-http://localhost:3000}/api/health" >/dev/null 2>&1; then
  BASE_URL="${BASE_URL:-http://localhost:3000}" npm run test:e2e:node || { echo "❌ E2E tests failed"; exit 1; }
  echo "✅ E2E tests passed"
else
  echo "⏭️  Skipped fast E2E (no server at ${BASE_URL:-http://localhost:3000}; CI runs full P0 matrix)"
fi

echo "🎉 All pre-push checks passed! Safe to push."
